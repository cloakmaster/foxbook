# Copy to .env.local (gitignored) and fill in for local development.
# Keys without a value are required; keys with a commented example show format.
# Keep this file in lockstep with docs/operations/env-vars.md.

# --- Database (Neon Postgres) ---
DATABASE_URL=                              # pooled Neon connection string (postgresql://...-pooler...)
DATABASE_URL_DIRECT=                       # non-pooled Neon connection — migrations + transactions needing pg_advisory_xact_lock

# --- Transparency-log signing ---
FOXBOOK_LOG_SIGNING_KEY_HEX=               # Ed25519 STH-signing private key, 64-char hex (32 bytes). Public counterpart served at /.well-known/foxbook.json. Generated offline; never commit.

# --- Email ---
RESEND_API_KEY=                            # re_...  transactional email (claim-flow notifications)

# --- Feature flags ---
# FOXBOOK_FIREHOSE_ENABLED=true            # opt in to the SSE /firehose LISTEN/NOTIFY subscriber. Disabled by default since #84 ("true" enables; anything else disables).

# --- Tooling (optional) ---
# GITHUB_PERSONAL_ACCESS_TOKEN=            # scopes: repo, read:org, workflow (for the GitHub MCP server)

# --- Do NOT add: ---
# SCOUT_WALLET_PRIVATE_KEY_*               # scout wallet key management unresolved — filed for a future ADR if/when scouts ship.
#                                          # Must be KMS-ARN or Cloudflare Workers Secret binding, never plaintext.
