# Copy to .env.local (gitignored) and fill in for local development.
# Keys without a value are required; keys with a commented example show format.

# --- Day 1 ---
GITHUB_PERSONAL_ACCESS_TOKEN=              # scopes: repo, read:org, workflow (for GitHub MCP)

# --- Day 2 ---
DATABASE_URL=                              # pooled Neon connection string (postgresql://...-pooler...)
RESEND_API_KEY=                            # re_...  transactional email; DNS wiring on foxbook.dev lands day 3

# --- Day 3+ ---
# NEON_API_KEY=                            # remote MCP endpoint preferred (see docs/operations/env-vars.md)
# CLOUDFLARE_API_TOKEN=                    # DNS, Workers, Durable Objects, R2
# VERCEL_TOKEN=                            # deploy status, env var management
# SENTRY_AUTH_TOKEN=                       # error triage, release tracking

# --- Do NOT add: ---
# SCOUT_WALLET_PRIVATE_KEY_*               # scout wallet key management unresolved — week-2 architecture decision.
#                                          # Must be KMS-ARN or Cloudflare Workers Secret binding, never plaintext.
