{
  "name": "@foxbook/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle Postgres schema + migrations.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "lint": "biome lint .",
    "db:generate": "node --env-file=../../.env.local --no-warnings node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "node --env-file=../../.env.local --no-warnings node_modules/drizzle-kit/bin.cjs push",
    "db:migrate": "node --env-file=../../.env.local --no-warnings ./scripts/migrate.mjs",
    "db:migrate:kit": "node --env-file=../../.env.local --no-warnings node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "node --env-file=../../.env.local --no-warnings node_modules/drizzle-kit/bin.cjs studio",
    "db:delete-claim": "node --env-file=../../.env.local --no-warnings ./scripts/delete-claim.mjs"
  },
  "dependencies": {
    "@foxbook/core": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
