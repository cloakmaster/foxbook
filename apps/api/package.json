{
  "name": "@foxbook/api",
  "version": "0.0.0",
  "private": true,
  "description": "API routes for /api/v1/*.",
  "type": "module",
  "main": "./src/server.ts",
  "types": "./src/server.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint .",
    "dev": "node --env-file=../../.env.local --import tsx ./src/main.ts",
    "start": "node --import tsx ./src/main.ts",
    "smoke:tier1": "node --env-file=../../.env.local --import tsx ./scripts/smoke-test-tier1.ts",
    "smoke:revoke": "node --env-file=../../.env.local --import tsx ./scripts/smoke-test-revoke.ts"
  },
  "dependencies": {
    "@foxbook/adapter-dns": "workspace:*",
    "@foxbook/adapter-endpoint-challenge": "workspace:*",
    "@foxbook/adapter-gist": "workspace:*",
    "@foxbook/core": "workspace:*",
    "@foxbook/db": "workspace:*",
    "@foxbook/types-ts": "workspace:*",
    "@foxbook/validators": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.24",
    "tsx": "^4.22.4",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "vitest": "^4.1.8"
  }
}
