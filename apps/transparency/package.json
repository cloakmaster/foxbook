{
  "name": "@foxbook/transparency",
  "version": "0.0.0",
  "private": true,
  "description": "transparency.foxbook.dev — Cloudflare Worker serving the Merkle transparency log read surface. Read-only; never writes, never appends.",
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome lint .",
    "dev": "wrangler dev",
    "cf:login": "wrangler login",
    "cf:secret": "wrangler secret put DATABASE_URL",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@foxbook/db": "workspace:*",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "vitest": "^4.1.5",
    "wrangler": "^3.95.0"
  }
}
